# ====================================
# KANAEKU TORI BOT - ENVIRONMENT CONFIG
# ====================================

# ============ BOT CONFIGURATION ============
# Get your bot token from @BotFather on Telegram
# Example: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-1234567
BOT_TOKEN=your_telegram_bot_token_here

# Bot display name
BOT_NAME=Kanaeku Tori

# Bot version (for display purposes)
BOT_VERSION=1.0.1

# ============ ADMIN CONFIGURATION ============
# Your Telegram user ID (get it from @userinfobot)
# Example: 123456789
ADMIN_ID=your_telegram_user_id_here

# Multiple admins (comma-separated, optional)
# ADMIN_IDS=123456789,987654321,555555555

# ============ LOGGING CONFIGURATION ============
# Enable file logging (true/false)
LOG_TO_FILE=false

# Enable debug mode (true/false)
DEBUG=false

# Log level: info, warn, error, debug
LOG_LEVEL=info

# ============ DATABASE CONFIGURATION ============
# Database type: mysql, postgres, mongodb, sqlite, none
DB_TYPE=none

# MySQL/PostgreSQL Configuration
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=your_database_password
# DB_NAME=kanaeku_bot

# MongoDB Configuration
# MONGO_URI=mongodb://localhost:27017/kanaeku_bot

# SQLite Configuration
# SQLITE_PATH=./data/bot.db

# ============ FEATURE FLAGS ============
# Enable/disable specific features
ENABLE_STATS=true
ENABLE_QUOTES=true
ENABLE_GAMES=true

# ============ API KEYS (Optional) ============
# Add your API keys for various services here

# OpenWeather API (for weather plugin)
# OPENWEATHER_API_KEY=your_api_key_here

# News API (for news plugin)
# NEWS_API_KEY=your_api_key_here

# YouTube API (for YouTube plugin)
# YOUTUBE_API_KEY=your_api_key_here

# ============ RATE LIMITING ============
# Maximum commands per user per minute
# RATE_LIMIT_PER_MINUTE=20

# ============ PLUGIN CONFIGURATION ============
# Disable specific plugins (comma-separated)
# DISABLED_PLUGINS=quote,dice

# ============ NOTIFICATION SETTINGS ============
# Send error notifications to admin (true/false)
# NOTIFY_ADMIN_ON_ERROR=false

# Send startup notification to admin (true/false)
# NOTIFY_ADMIN_ON_START=false

# ============ ADVANCED SETTINGS ============
# Polling interval in milliseconds
# POLLING_INTERVAL=300

# Request timeout in milliseconds
# REQUEST_TIMEOUT=60000

# Maximum file upload size in MB
# MAX_FILE_SIZE=20

# ============ TIMEZONE ============
# Set your timezone (optional)
# TZ=Asia/Jakarta

# ============ NOTES ============
# 1. Rename this file to .env before using
# 2. Never commit .env to version control
# 3. Keep your tokens and API keys secret
# 4. Get BOT_TOKEN from: https://t.me/botfather
# 5. Get your user ID from: https://t.me/userinfobot
